  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
