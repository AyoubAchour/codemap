{
  "name": "codemap-mcp",
  "version": "0.6.0",
  "type": "module",
  "license": "MIT",
  "description": "Local-first persistent codebase memory for MCP-enabled coding agents.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "knowledge-graph",
    "codebase",
    "codebase-memory",
    "ai-agents",
    "agent"
  ],
  "homepage": "https://github.com/AyoubAchour/codemap",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AyoubAchour/codemap.git"
  },
  "bugs": {
    "url": "https://github.com/AyoubAchour/codemap/issues"
  },
  "author": "Ayoub Achour",
  "bin": {
    "codemap": "dist/cli/codemap.js",
    "codemap-mcp": "dist/cli/codemap-mcp.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "dist/cli/codemap.js",
    "dist/cli/codemap-mcp.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --target=node bin/codemap-mcp.ts --outfile dist/cli/codemap-mcp.js && bun build --target=node bin/codemap.ts --outfile dist/cli/codemap.js",
    "build:binary": "bun build --compile bin/codemap-mcp.ts --outfile dist/codemap-mcp",
    "lint": "biome check src test",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "fastest-levenshtein": "^1.0.16",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
