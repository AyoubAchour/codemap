{
  "name": "codemap-mcp",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Persistent knowledge graph of a codebase, exposed via MCP.",
  "bin": {
    "codemap": "./bin/codemap.ts",
